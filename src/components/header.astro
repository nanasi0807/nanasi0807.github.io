---
import Link from '@/components/link.astro'
import ThemeToggle from '@/components/theme-toggle.astro'
import { NAV_LINKS, SITE } from '@/consts'
import { Image } from 'astro:assets'
import logo from '../../public/static/logo.png'
---

<div>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4"
  >
    <Link href="/" class="flex shrink-0 items-center justify-center gap-3">
      <Image
        src={logo}
        alt="Logo"
        class="h-8 w-8 sm:h-10 sm:w-10 rounded-md object-cover"
      />
      <span
        class="hidden min-[400px]:block text-xl sm:text-2xl leading-none font-semibold tracking-tight"
      >
        {SITE.title}
      </span>
    </Link>

    <div class="flex items-center gap-4">
      <nav class="flex items-center gap-4 text-sm sm:gap-6">
        {
          NAV_LINKS.map((item) => (
            <Link
              href={item.href}
              class="text-foreground/60 hover:text-foreground capitalize transition-colors"
            >
              {item.label}
            </Link>
          ))
        }
      </nav>
      <ThemeToggle transition:persist />
    </div>
  </div>
</div>