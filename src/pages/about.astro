---
import Breadcrumbs from '@/components/breadcrumbs.astro'
import Link from '@/components/link.astro'
import PageHead from '@/components/page-head.astro'
import Layout from '@/layouts/layout.astro'
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section>
    <div class="min-w-full">
      <div class="prose mb-8 text-muted-foreground">
        <p class="mt-0">
          I'm n4n4s1, a student at the University of Information Technology (VNU-UIT).
          I wouldn't call myself a reverse engineer yet, because I still have a lot to learn.
        </p>

        <p>
          I've been playing CTFs and wargame challenges since November 2024.
          Right now, I'm mainly focused on Android and kernel reversing.
          I also play CTFs with my teams:
          <Link
            href="https://ctftime.org/team/280950/"
            external
            underline
            class="text-foreground font-medium"
          >
            V1t
          </Link>
          and
          <Link
            href="https://ctftime.org/team/28797"
            external
            underline
            class="text-foreground font-medium"
          >
            PwnSec
          </Link>.
        </p>

        <p>
          You can reach me on Discord:
          <span class="font-medium text-foreground">dr34mch4s3r</span>
        </p>
      </div>

      <h2 class="mb-4 text-2xl font-medium text-foreground">My playlist</h2>
      <p class="mb-4 text-muted-foreground">
        My hobby is pretty simple: I just enjoy listening to music. Here's my playlist if you'd like to check it out.
      </p>

      <div class="mt-4 overflow-hidden rounded-xl">
        <iframe
          data-testid="embed-iframe"
          style="border-radius:12px"
          src="https://open.spotify.com/embed/playlist/2FZJoB35XnCGw15G5Kbzfq?utm_source=generator"
          width="100%"
          height="352"
          frameborder="0"
          allowfullscreen
          allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
          loading="lazy"
        ></iframe>
      </div>
    </div>
  </section>
</Layout>